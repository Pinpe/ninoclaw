{
    "//": "== 模型和API调用 ==",
        "base_url"                       : "https://api.moonshot.cn/v1",
        "model"                          : "kimi-k2.5",
        "think"                          : false,  "//" : "true和false开关思考模式，null则不指定",
        "api_time_out"                   : 15,
        "api_retry_sleep"                : 3,
        "api_retry_num"                  : 2,
        "connect_check"                  : true,
        "connect_check_time_out"         : 5,
    "//": "== Agent行为和管理 ==",
        "sub_agent_max_steps"            : 7,
        "diary_tip_interval"             : 3,
        "cmd_start_tag"                  : "[COMMAND]",
        "cmd_end_tag"                    : "[/COMMAND]",
        "task_start_tag"                 : "[TASK]",
        "task_end_tag"                   : "[/TASK]",
        "result_start_tag"               : "[RESULT]",
        "result_end_tag"                 : "[/RESULT]",
        "prompt_template_name"           : "梦眠",
        "prompt_template_path"           : "/home/pinpe/文档/代码和项目/ninoclaw/prompt_template/yume.md",
        "sub_agent_prompt_template_path" : "/home/pinpe/文档/代码和项目/ninoclaw/prompt_template/exec.md",
    "//": "== 命令执行器 ==",
        "cmd_censor"                     : false,
        "shell"                          : "/usr/bin/fish",
        "shell_config"                   : "/home/pinpe/.config/fish/config.fish",
        "home_path"                      : "/home/pinpe/文档/代码和项目/ninoclaw/home",
        "cmd_time_out"                   : 40,
        "cmd_sleep"                      : 0.5,
    "//": "== 上下文管理 ==",
        "context_len"                    : 30,
        "context_summary_len"            : 200,
        "context_summary_input_len"      : 25,
    "//": "== 杂项 ==",
        "show_notify"                    : true,
    "//": "== 技能 ==",
        "skill": [
            "当需要搜索日记的内容时：`find <日记目录的路径> -name \"*.md\" | xargs grep \"<关键词>\"`",
            "当需要访问网站时：`web \"<你需要访问的URL>\"`",
            "当遇到自己不会的问题时：`get-llm \"<发送的消息>\"`",
            "当查看图片：`vision \"<图片文件路径>\"`",
            "当需要查看图片里的文本：`ocr \"<图片文件路径>\"`",
            "当需要查询天气：`weather \"<想要查询的城市>\"`",
            "当需要播放音频给用户听（注意有两个play）：`play play \"<音频文件路径>\"`",
            "当需要查看用户的倒数日内容，以便规划行程：`days`；也可以添加倒数日：`days -a <名称> -i <emoji图标> -d <YYYY-MM-DD>`"
        ]
}
